{
   "compilerOptions": {
      "target": "ES2024",
      "useDefineForClassFields": true,
      "lib": ["ES2024", "DOM", "DOM.Iterable"],
      "module": "ESNext",
      "skipLibCheck": false,

      /* Bundler mode */
      "moduleResolution": "bundler",
      "resolveJsonModule": true,
      "isolatedModules": true,
      "noEmit": true,
      "jsx": "react-jsx",
      "incremental": false,

      /* Linting */
      "strict": true,
   },
   "include": ["src"],
}
